captured_white=[]
captured_black=[]
difficulty = 2

hint_count = 0
MAX_HINTS = 2

pieces={
"P":"♙","R":"♖","N":"♘","B":"♗","Q":"♕","K":"♔",
"p":"♟","r":"♜","n":"♞","b":"♝","q":"♛","k":"♚"
}

# ------------------ BOARD ------------------

def board_to_unicode():
 rows=[]
 for rank in range(7,-1,-1):
  row=[]
  for file in range(8):
   piece=board.piece_at(chess.square(file,rank))
   row.append(pieces[piece.symbol()] if piece else "")
  rows.append(row)
 return rows

def get_moves(square):
 return [m.to_square for m in board.legal_moves if m.from_square==square]

def get_threatened_pieces():
 threatened=[]
 for square, piece in board.piece_map().items():
  if piece.color == board.turn:
   if board.is_attacked_by(not board.turn, square):
    threatened.append(square)
 return threatened

# ------------------ AI ------------------

def evaluate():
 values={chess.PAWN:100,chess.KNIGHT:320,chess.BISHOP:330,
         chess.ROOK:500,chess.QUEEN:900,chess.KING:20000}
 score=0
 for p in values:
  score+=len(board.pieces(p,chess.WHITE))*values[p]
  score-=len(board.pieces(p,chess.BLACK))*values[p]
 return score

def alphabeta(depth,alpha,beta,maxi):
 if depth==0 or board.is_game_over(): return evaluate()

 if maxi:
  m=-999999
  for move in board.legal_moves:
   board.push(move)
   v=alphabeta(depth-1,alpha,beta,False)
   board.pop()
   m=max(m,v); alpha=max(alpha,v)
   if beta<=alpha: break
  return m
 else:
  m=999999
  for move in board.legal_moves:
   board.push(move)
   v=alphabeta(depth-1,alpha,beta,True)
   board.pop()
   m=min(m,v); beta=min(beta,v)
   if beta<=alpha: break
  return m

def get_best_move(depth,white):
 best=None
 if white:
  val=-999999
  for m in board.legal_moves:
   board.push(m)
   v=alphabeta(depth-1,-999999,999999,False)
   board.pop()
   if v>val: val=v; best=m
 else:
  val=999999
  for m in board.legal_moves:
   board.push(m)
   v=alphabeta(depth-1,-999999,999999,True)
   board.pop()
   if v<val: val=v; best=m
 return best

