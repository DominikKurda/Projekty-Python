# ------------------ ROUTES ------------------

@app.route("/")
def index():
 return render_template_string(HTML)

@app.route("/level/<int:lvl>")
def level(lvl):
 global difficulty
 difficulty=lvl
 return "OK"

@app.route("/hint")
def hint():
 global hint_count

 if hint_count >= MAX_HINTS:
  return jsonify({"move":None,"hint":None})

 hint_count += 1
 move=get_best_move(2, True)

 return jsonify({
  "move":{
   "fromX":chess.square_file(move.from_square),
   "fromY":7-chess.square_rank(move.from_square),
   "toX":chess.square_file(move.to_square),
   "toY":7-chess.square_rank(move.to_square)
  },
  "hint":f"{chess.square_file(move.to_square)}_{7-chess.square_rank(move.to_square)}"
 })

@app.route("/board")
def get_board():
 return jsonify({
  "board":board_to_unicode(),
  "captured":{"white":captured_white,"black":captured_black}
 })

@app.route("/legal",methods=["POST"])
def legal():
 data=request.json
 x,y=data["square"].split("_")
 square=chess.square(int(x),7-int(y))

 moves=[f"{chess.square_file(m)}_{7-chess.square_rank(m)}" for m in get_moves(square)]
 threatened=[f"{chess.square_file(s)}_{7-chess.square_rank(s)}" for s in get_threatened_pieces()]

 return jsonify({"board":board_to_unicode(),"moves":moves,"threatened":threatened})

@app.route("/move",methods=["POST"])
def move():
 data=request.json
 fx,fy=data["from"].split("_")
 tx,ty=data["to"].split("_")

 move=chess.Move(chess.square(int(fx),7-int(fy)), chess.square(int(tx),7-int(ty)))

 sound="move"

 if move in board.legal_moves:

  if board.is_capture(move):
   sound="capture"

  board.push(move)

  if board.is_check():
   sound="check"

  if board.is_checkmate():
   sound="mate"

  if not board.is_game_over():
   if difficulty==1:
    ai=random.choice(list(board.legal_moves))
   else:
    depth=2 if difficulty==2 else 3
    ai=get_best_move(depth, False)

   if ai:
    board.push(ai)

 return jsonify({
  "board":board_to_unicode(),
  "captured":{"white":captured_white,"black":captured_black},
  "sound":sound
 })

@app.route("/new")
def new():
