@app.get("/")
def index():
    today = date.today()

    y = int(request.args.get("y", today.year))
    m = int(request.args.get("m", today.month))
    d = request.args.get("d", None)

    if d is None:
        selected_day = today.day if (y == today.year and m == today.month) else 1
    else:
        selected_day = max(1, min(31, int(d)))

    cal = calendar.Calendar(firstweekday=0)  # Monday=0
    month_days = list(cal.itermonthdates(y, m))

    events = load_events()
    counts = {}
    for e in events:
        counts[e["date"]] = counts.get(e["date"], 0) + 1

    cells = []
    for dt in month_days:
        iso = dt.isoformat()
        cells.append({
            "y": dt.year,
            "m": dt.month,
            "d": dt.day,
            "muted": (dt.month != m),
            "count": counts.get(iso, 0),
            "is_today": (dt == today)
        })

    last_day = calendar.monthrange(y, m)[1]
    selected_day = min(selected_day, last_day)

    selected_date = date(y, m, selected_day)
    selected_iso = selected_date.isoformat()

    # NIEOGRANICZONE: bierzemy wszystkie eventy z dnia
    selected_events = sort_events_in_day(events_for_day(events, selected_iso))

    prev_y, prev_m = (y - 1, 12) if m == 1 else (y, m - 1)
    next_y, next_m = (y + 1, 1) if m == 12 else (y, m + 1)

    month_name = {
        1:"Styczeń",2:"Luty",3:"Marzec",4:"Kwiecień",5:"Maj",6:"Czerwiec",
        7:"Lipiec",8:"Sierpień",9:"Wrzesień",10:"Październik",11:"Listopad",12:"Grudzień"
    }[m]

    weekdays = ["Pon", "Wto", "Śro", "Czw", "Pią", "Sob", "Nie"]
    selected_human = selected_date.strftime("%d.%m.%Y")

    accent = MONTH_COLORS.get(m, "#7c3aed")

    return render_template_string(
        TEMPLATE,
        y=y, m=m,
        prev_y=prev_y, prev_m=prev_m,
        next_y=next_y, next_m=next_m,
        month_name=month_name,
        weekdays=weekdays,
        calendar_cells=cells,
        selected_day_num=selected_day,
        selected_date_iso=selected_iso,
        selected_date_human=selected_human,
        selected_events=selected_events,
        email_enabled=can_send_email(),
        notify_to=NOTIFY_TO,
        default_time=DEFAULT_EVENT_TIME_IF_EMPTY.strftime("%H:%M"),
        accent=accent
    )

@app.post("/add")
def add_event():
    y = request.args.get("y")
    m = request.args.get("m")
    d = request.args.get("d")

    title = (request.form.get("title") or "").strip()
    dt = (request.form.get("date") or "").strip()
    tm = (request.form.get("time") or "").strip()
    desc = (request.form.get("description") or "").strip()

    if not title or not dt:
        return redirect(url_for("index", y=y, m=m, d=d))

    # walidacja daty
    try:
        datetime.strptime(dt, "%Y-%m-%d")
    except ValueError:
        return redirect(url_for("index", y=y, m=m, d=d))

    # walidacja czasu (opcjonalnie)
    if tm:
        try:
            datetime.strptime(tm, "%H:%M")
        except ValueError:
            tm = ""

    e = {
        "id": uuid.uuid4().hex,
        "title": title,
        "date": dt,
        "time": tm,
        "description": desc
    }

    events = load_events()
    events.append(e)
    save_events(events)

    # mail dzień wcześniej
    schedule_email_day_before(e)

    yyyy, mm, dd = dt.split("-")
    return redirect(url_for("index", y=int(yyyy), m=int(mm), d=int(dd)))

@app.post("/bulk_add")
def bulk_add():
    y = request.args.get("y")
    m = request.args.get("m")
    d = request.args.get("d")

    target_date = (request.form.get("date") or "").strip()
    bulk_text = (request.form.get("bulk") or "")

    # walidacja daty
    try:
        datetime.strptime(target_date, "%Y-%m-%d")
    except ValueError:
        return redirect(url_for("index", y=y, m=m, d=d))

    new_events = parse_bulk_lines(bulk_text, target_date)
    if not new_events:
        yyyy, mm, dd = target_date.split("-")
        return redirect(url_for("index", y=int(yyyy), m=int(mm), d=int(dd)))

    events = load_events()
    events.extend(new_events)
    save_events(events)

    # zaplanuj maile (dzień wcześniej) dla wszystkich
    for e in new_events:
        schedule_email_day_before(e)

    yyyy, mm, dd = target_date.split("-")
    return redirect(url_for("index", y=int(yyyy), m=int(mm), d=int(dd)))

@app.get("/delete/<event_id>")
def delete_event(event_id):
    y = request.args.get("y")
    m = request.args.get("m")
    d = request.args.get("d")

    events = load_events()
    events = [e for e in events if e.get("id") != event_id]
    save_events(events)

    # usuń job maila
    job_id = f"email_{event_id}"
    try:
        scheduler.remove_job(job_id)
    except Exception:
        pass

    return redirect(url_for("index", y=y, m=m, d=d))

