# ----------------------------
# STORAGE
# ----------------------------
def load_events():
    if not os.path.exists(DATA_FILE):
        return []
    try:
        with open(DATA_FILE, "r", encoding="utf-8") as f:
            data = json.load(f)
            return data if isinstance(data, list) else []
    except Exception:
        return []

def save_events(events):
    with open(DATA_FILE, "w", encoding="utf-8") as f:
        json.dump(events, f, ensure_ascii=False, indent=2)

def events_for_day(events, yyyy_mm_dd: str):
    # NIEOGRANICZONE: zwracamy WSZYSTKIE wydarzenia danego dnia
    return [e for e in events if e.get("date") == yyyy_mm_dd]

def sort_events_in_day(day_events):
    # Najpierw z godziną rosnąco, potem bez godziny
    def key(e):
        t = (e.get("time") or "").strip()
        return (t == "", t)
    return sorted(day_events, key=key)

# ----------------------------
# EMAIL
# ----------------------------
def can_send_email() -> bool:
    return bool(EMAIL_USER and EMAIL_PASS)

def send_email(subject: str, body: str, to_list: list[str]):
    if not can_send_email():
        return False, "Brak CAL_EMAIL_USER / CAL_EMAIL_PASS."

    msg = EmailMessage()
    msg["From"] = EMAIL_USER
    msg["To"] = ", ".join(to_list)
    msg["Subject"] = subject
    msg.set_content(body)

    try:
        with smtplib.SMTP(SMTP_HOST, SMTP_PORT, timeout=20) as server:
            server.ehlo()
            server.starttls()
            server.login(EMAIL_USER, EMAIL_PASS)
            server.send_message(msg)
        return True, "OK"
    except Exception as e:
        return False, str(e)

def parse_date(dt_str: str) -> date | None:
    try:
        return datetime.strptime(dt_str, "%Y-%m-%d").date()
    except Exception:
        return None

def parse_time(tm_str: str) -> dtime | None:
    try:
        return datetime.strptime(tm_str, "%H:%M").time()
    except Exception:
        return None

def event_datetime_for_scheduling(e) -> datetime | None:
    """
    Jeśli event ma godzinę -> użyj jej.
    Jeśli nie ma godziny -> użyj DEFAULT_EVENT_TIME_IF_EMPTY.
    """
    dt = parse_date((e.get("date") or "").strip())
    if not dt:
        return None

    tm_raw = (e.get("time") or "").strip()
    tm = parse_time(tm_raw) if tm_raw else None
    if tm is None:
        tm = DEFAULT_EVENT_TIME_IF_EMPTY

    return datetime.combine(dt, tm)

def schedule_email_day_before(e):
    """
    Mail dzień przed wydarzeniem:
    run_at = event_dt - 1 dzień
    """
    ev_dt = event_datetime_for_scheduling(e)
    if not ev_dt:
        return

    run_at = ev_dt - timedelta(days=1)
    if run_at <= datetime.now():
        return

    job_id = f"email_{e['id']}"

    # usuń stary job (jeśli istnieje)
    try:
        scheduler.remove_job(job_id)
    except Exception:
        pass

    def job():
        subject = f"Przypomnienie (dzień wcześniej): {e.get('title', 'Wydarzenie')}"
        body = (
            "To jest automatyczne przypomnienie z kalendarza (1 dzień przed).\n\n"
            f"Tytuł: {e.get('title','')}\n"
            f"Data: {e.get('date','')}\n"
            f"Godzina: {e.get('time','(brak)')}\n"
            f"Opis: {e.get('description','')}\n"
        )
        send_email(subject, body, NOTIFY_TO)

    scheduler.add_job(job, "date", run_date=run_at, id=job_id, replace_existing=True)

def reschedule_all_events():
    # po restarcie aplikacji odtwarzamy przypomnienia dla przyszłych eventów
    events = load_events()
    for e in events:
        schedule_email_day_before(e)

# ----------------------------
# MULTI-ADD (hurtowe dodawanie)
# Format linii:
#  - "HH:MM | Tytuł | opis"
#  - albo "Tytuł | opis" (bez godziny)
#  - albo samo "Tytuł"
# Separator: | (pipe)
# ----------------------------
def parse_bulk_lines(bulk_text: str, target_date_iso: str):
    out = []
    lines = (bulk_text or "").splitlines()
    for raw in lines:
        line = raw.strip()
        if not line:
            continue

        parts = [p.strip() for p in line.split("|")]

        ev_time = ""
        title = ""
        desc = ""

        if len(parts) >= 3:
            ev_time, title, desc = parts[0], parts[1], " | ".join(parts[2:])
        elif len(parts) == 2:
            maybe_time = parts[0]
            if parse_time(maybe_time) is not None:
                ev_time = maybe_time
                title = parts[1]
                desc = ""
            else:
                title = parts[0]
                desc = parts[1]
        else:
            title = parts[0]
            desc = ""

        if not title:
            continue

        if ev_time and parse_time(ev_time) is None:
            ev_time = ""

        e = {
            "id": uuid.uuid4().hex,
            "title": title,
            "date": target_date_iso,
            "time": ev_time,
            "description": desc
        }
        out.append(e)

    return out

